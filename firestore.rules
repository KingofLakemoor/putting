rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow read access for all authenticated users to all collections
    match /{document=**} {
      allow read: if request.auth != null;
    }

    // Allow any authenticated user to create a player profile (universal access to addplayer)
    // and update an existing profile (for UID merging)
    match /putting_league_players/{playerId} {
      allow create: if request.auth != null;
      // Allow the user to update their player record to merge the UID.
      allow update: if request.auth != null;
      // Admin-only operations for other modifications
      allow delete: if request.auth.token.admin == true;
    }

    // Default write rule (deny all other writes unless explicitly allowed above or by an Admin)
    match /{document=**} {
      allow write: if request.auth.token.admin == true;
    }
  }
}
