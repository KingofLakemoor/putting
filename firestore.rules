rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isCoordinator() {
      return request.auth != null && exists(/databases/$(database)/documents/putting_league_coordinators/$(request.auth.uid));
    }

    // Players collection
    match /putting_league_players/{playerId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Allow the user to update their player record to merge the UID.
      allow update: if request.auth != null && (
        isAdmin() ||
        isCoordinator() ||
        resource.data.uid == request.auth.uid ||
        (
          (!('uid' in resource.data) || resource.data.uid == null || resource.data.uid.size() == 36) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uid', 'name']) &&
          request.resource.data.uid == request.auth.uid
        )
      );
      // Admin-only operations for other modifications
      allow delete: if isAdmin() || isCoordinator();
    }

    // Scores collection
    match /putting_league_scores/{scoreId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if isAdmin() || isCoordinator();
    }

    // Rounds collection
    match /putting_league_rounds/{roundId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (isAdmin() || isCoordinator() || request.resource.data.player_id == request.auth.uid);
      allow update, delete: if request.auth != null && (isAdmin() || isCoordinator() || resource.data.player_id == request.auth.uid);
    }

    // Courses collection
    match /putting_league_courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Coordinators collection
    match /putting_league_coordinators/{coordinatorId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Settings collection
    match /putting_league_settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Cup Points collection
    match /putting_league_cup_points/{pointId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isCoordinator();
    }

    // Matchups collection
    match /putting_league_matchups/{matchupId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isCoordinator();
    }

    // Default deny rule for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
